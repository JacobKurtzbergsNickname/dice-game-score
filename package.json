    "@tailwindcss/postcss": "^4.2.1",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.1.0",
    "angular-eslint": "^21.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
